# PicSnap environment variables
# Copy this file to .env and fill in your own values.
# All client-side vars must be prefixed with VITE_ to be exposed to the app.

# Mapillary API access token — required for the "Geo-Roulette" category.
# Get a free token at https://www.mapillary.com/dashboard/developers
VITE_MAPILLARY_TOKEN=
